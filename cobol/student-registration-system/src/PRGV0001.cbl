000001 IDENTIFICATION DIVISION.
000002 PROGRAM-ID. PRGV0001.
000003 AUTHOR. SRIDHAR.
000004*LOAD SEQUENTIAL STUDENT FILE INTO INDEXED FILE
000005 ENVIRONMENT DIVISION.
000006 INPUT-OUTPUT SECTION.
000007 FILE-CONTROL.
000008     SELECT STUDENT-SEQ-FILE
000009         ASSIGN TO "../data/STUDENTSEQ.DAT"
000010         ORGANIZATION IS LINE SEQUENTIAL.
000011
000012     SELECT STUDENT-IDX-FILE
000013         ASSIGN TO "../indexed/STUDENTIDX.DAT"
000014         ORGANIZATION IS INDEXED
000015         ACCESS MODE IS DYNAMIC
000016         RECORD KEY IS STUDENT-ID OF IDX-STUDENT-REC
000017         FILE STATUS IS WS-IDX-STATUS.
000018
000019 DATA DIVISION.
000020 FILE SECTION.
000021
000022 FD STUDENT-SEQ-FILE.
000023 01 SEQ-STUDENT-REC.
000024 COPY "../copybooks/STUDENT.CPY".
000025
000026 FD STUDENT-IDX-FILE.
000027 01 IDX-STUDENT-REC.
000028 COPY "../copybooks/STUDENT.CPY".
000029
000030 WORKING-STORAGE SECTION.
000031 01 WS-EOF             PIC X VALUE "N".
000032    88 EOF-REACHED     VALUE "Y".
000033    88 NOT-EOF         VALUE "N".
000034
000035 01 WS-COUNT           PIC 9(4) VALUE 0.
000036 01 WS-IDX-STATUS      PIC XX VALUE SPACES.
000037
000038 PROCEDURE DIVISION.
000039 MAIN-PARA.
000040     DISPLAY "========================================".
000041     DISPLAY " PRGV0001 - GENERATE INDEXED FILE".
000042     DISPLAY "========================================".
000043
000044     OPEN INPUT STUDENT-SEQ-FILE.
000045     OPEN OUTPUT STUDENT-IDX-FILE.
000046
000047     PERFORM UNTIL EOF-REACHED
000048         READ STUDENT-SEQ-FILE
000049             AT END
000050                 SET EOF-REACHED TO TRUE
000051             NOT AT END
000052                 MOVE SEQ-STUDENT-REC TO IDX-STUDENT-REC
000053                 WRITE IDX-STUDENT-REC
000054                 IF WS-IDX-STATUS = "00"
000055                     ADD 1 TO WS-COUNT
000056                 ELSE
000057                     DISPLAY "WRITE ERROR. STATUS: " WS-IDX-STATUS
000058                     DISPLAY "STUDENT ID: "
000059                             STUDENT-ID OF IDX-STUDENT-REC
000060                 END-IF
000061         END-READ
000062     END-PERFORM.
000063
000064     CLOSE STUDENT-SEQ-FILE.
000065     CLOSE STUDENT-IDX-FILE.
000066
000067     DISPLAY "TOTAL STUDENTS LOADED: " WS-COUNT.
000068     DISPLAY "INDEXED FILE CREATED.".
000069
000070     STOP RUN.
000071 END PROGRAM PRGV0001.
