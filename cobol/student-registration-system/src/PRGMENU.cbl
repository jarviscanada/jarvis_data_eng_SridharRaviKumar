000001 IDENTIFICATION DIVISION.
000002 PROGRAM-ID. PRGMENU.
000003 AUTHOR. SRIDHAR.
000004*MAIN MENU FOR STUDENT REGISTRATION SYSTEM
000005 DATA DIVISION.
000006 WORKING-STORAGE SECTION.
000007 01 WS-OPTION          PIC 9 VALUE 0.
000008 01 WS-EXIT-FLAG       PIC X VALUE "N".
000009    88 EXIT-PROGRAM    VALUE "Y".
000010    88 CONTINUE-PROG   VALUE "N".
000011
000012 PROCEDURE DIVISION.
000013 MAIN-PARA.
000014     PERFORM UNTIL EXIT-PROGRAM
000015         PERFORM DISPLAY-MENU
000016         ACCEPT WS-OPTION
000017
000018         EVALUATE WS-OPTION
000019             WHEN 1
000020                 CALL "PRGV0001"
000021             WHEN 2
000022                 CALL "PRGI0002"
000023             WHEN 3
000024                 CALL "PRGU0003"
000025             WHEN 4
000026                 CALL "PRGD0004"
000027             WHEN 5
000028                 CALL "PRGQ0005"
000029             WHEN 6
000030                 CALL "PRGQ0006"
000031             WHEN 7
000032                 CALL "PRGQ0007"
000033             WHEN 8
000034                 CALL "PRGR0008"
000035             WHEN 9
000036                 SET EXIT-PROGRAM TO TRUE
000037             WHEN OTHER
000038                 DISPLAY "INVALID OPTION. PLEASE CHOOSE 1 TO 9."
000039         END-EVALUATE
000040
000041         IF NOT EXIT-PROGRAM
000042             DISPLAY " "
000043             DISPLAY "PRESS ENTER TO RETURN TO MENU..."
000044             ACCEPT WS-OPTION
000045         END-IF
000046     END-PERFORM.
000047
000048     DISPLAY "EXITING STUDENT REGISTRATION SYSTEM."
000049     STOP RUN.
000050
000051 DISPLAY-MENU.
000052     DISPLAY "========================================".
000053     DISPLAY "             M A I N  M E N U".
000054     DISPLAY "========================================".
000055     DISPLAY "OPTIONS".
000056     DISPLAY "----------------------------------------".
000057     DISPLAY "1 - GENERATE VSAM FILE".
000058     DISPLAY "2 - INSERT STUDENT DATA".
000059     DISPLAY "3 - UPDATE STUDENT DATA".
000060     DISPLAY "4 - DELETE STUDENT DATA".
000061     DISPLAY "5 - CLASS QUERY ALL STUDENTS".
000062     DISPLAY "6 - QUERY STUDENT BY ID".
000063     DISPLAY "7 - QUERY BY DATE OF INCLUSION".
000064     DISPLAY "8 - REPORT FILE WITH COURSE BREAK".
000065     DISPLAY "9 - EXIT".
000066     DISPLAY "----------------------------------------".
000067     DISPLAY "CHOOSE YOUR OPTION 1 TO 9: ".
000068 END PROGRAM PRGMENU.
