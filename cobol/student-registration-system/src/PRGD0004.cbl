000001 IDENTIFICATION DIVISION.
000002 PROGRAM-ID. PRGD0004.
000003 AUTHOR. SRIDHAR.
000004*DELETE STUDENT FROM INDEXED FILE
000005 ENVIRONMENT DIVISION.
000006 INPUT-OUTPUT SECTION.
000007 FILE-CONTROL.
000008     SELECT STUDENT-IDX-FILE
000009         ASSIGN TO "../indexed/STUDENTIDX.DAT"
000010         ORGANIZATION IS INDEXED
000011         ACCESS MODE IS DYNAMIC
000012         RECORD KEY IS STUDENT-ID OF IDX-STUDENT-REC
000013         FILE STATUS IS WS-IDX-STATUS.
000014
000015 DATA DIVISION.
000016 FILE SECTION.
000017
000018 FD STUDENT-IDX-FILE.
000019 01 IDX-STUDENT-REC.
000020 COPY "../copybooks/STUDENT.CPY".
000021
000022 WORKING-STORAGE SECTION.
000023 01 WS-IDX-STATUS      PIC XX VALUE SPACES.
000024 01 WS-INPUT-ID        PIC 9(4).
000025 01 WS-CONFIRM         PIC X VALUE SPACE.
000026
000027 01 WS-DASH-LINE       PIC X(75).
000028
000029 01 WS-HEADER-LINE.
000030    05 FILLER          PIC X(5)  VALUE "ID   ".
000031    05 FILLER          PIC X(26)
000032       VALUE "NAME                      ".
000033    05 FILLER          PIC X(9)  VALUE "BDAY     ".
000034    05 FILLER          PIC X(17)
000035       VALUE "COURSE           ".
000036    05 FILLER          PIC X(9)  VALUE "INS-DATE ".
000037    05 FILLER          PIC X(8)  VALUE "UPD-DATE".
000038
000039 01 WS-REPORT-LINE.
000040    05 RPT-ID          PIC 9(4).
000041    05 FILLER          PIC X(1) VALUE SPACE.
000042    05 RPT-NAME        PIC X(25).
000043    05 FILLER          PIC X(1) VALUE SPACE.
000044    05 RPT-BDAY        PIC 9(8).
000045    05 FILLER          PIC X(1) VALUE SPACE.
000046    05 RPT-COURSE      PIC X(16).
000047    05 FILLER          PIC X(1) VALUE SPACE.
000048    05 RPT-INS-DATE    PIC 9(8).
000049    05 FILLER          PIC X(1) VALUE SPACE.
000050    05 RPT-UPD-DATE    PIC 9(8).
000051
000052 PROCEDURE DIVISION.
000053 MAIN-PARA.
000054     MOVE ALL "-" TO WS-DASH-LINE.
000055
000056     DISPLAY WS-DASH-LINE.
000057     DISPLAY "DELETE STUDENT".
000058     DISPLAY WS-DASH-LINE.
000059
000060     OPEN I-O STUDENT-IDX-FILE.
000061
000062     IF WS-IDX-STATUS NOT = "00"
000063         DISPLAY "OPEN ERROR STATUS: " WS-IDX-STATUS
000064         STOP RUN
000065     END-IF.
000066
000067     DISPLAY "ENTER STUDENT ID TO DELETE: ".
000068     ACCEPT WS-INPUT-ID.
000069
000070     MOVE WS-INPUT-ID TO STUDENT-ID OF IDX-STUDENT-REC.
000071
000072     READ STUDENT-IDX-FILE
000073         KEY IS STUDENT-ID OF IDX-STUDENT-REC
000074         INVALID KEY
000075             DISPLAY "STUDENT NOT FOUND: " WS-INPUT-ID
000076         NOT INVALID KEY
000077             DISPLAY "STUDENT FOUND"
000078             PERFORM DISPLAY-STUDENT
000079             PERFORM CONFIRM-DELETE
000080     END-READ.
000081
000082     CLOSE STUDENT-IDX-FILE.
000083
000084     STOP RUN.
000085
000086 CONFIRM-DELETE.
000087     DISPLAY "CONFIRM DELETE? Y/N: ".
000088     ACCEPT WS-CONFIRM.
000089
000090     IF WS-CONFIRM = "Y" OR WS-CONFIRM = "y"
000091         DELETE STUDENT-IDX-FILE
000092             INVALID KEY
000093                 DISPLAY "DELETE FAILED. STATUS: "
000094                         WS-IDX-STATUS
000095             NOT INVALID KEY
000096                 DISPLAY "STUDENT DELETED SUCCESSFULLY."
000097         END-DELETE
000098     ELSE
000099         DISPLAY "DELETE CANCELLED."
000100     END-IF.
000101
000102 DISPLAY-STUDENT.
000103     DISPLAY WS-DASH-LINE.
000104     DISPLAY WS-HEADER-LINE.
000105     DISPLAY WS-DASH-LINE.
000106     MOVE SPACES TO WS-REPORT-LINE.
000107     MOVE STUDENT-ID OF IDX-STUDENT-REC
000108         TO RPT-ID.
000109     MOVE STUDENT-NAME OF IDX-STUDENT-REC
000110         TO RPT-NAME.
000111     MOVE STUDENT-BIRTHDAY OF IDX-STUDENT-REC
000112         TO RPT-BDAY.
000113     MOVE STUDENT-COURSE OF IDX-STUDENT-REC
000114         TO RPT-COURSE.
000115     MOVE STUDENT-INS-DATE OF IDX-STUDENT-REC
000116         TO RPT-INS-DATE.
000117     MOVE STUDENT-UPD-DATE OF IDX-STUDENT-REC
000118         TO RPT-UPD-DATE.
000119     DISPLAY WS-REPORT-LINE.
000120     DISPLAY WS-DASH-LINE.
000121 END PROGRAM PRGD0004.
