000001 IDENTIFICATION DIVISION.
000002 PROGRAM-ID. PRGU0003.
000003 AUTHOR. SRIDHAR.
000004*PROGRAM : PRGU0003
000005*PURPOSE : UPDATE STUDENT IN INDEXED FILE
000006*INPUT   : STUDENT ID AND UPDATED STUDENT DETAILS
000007*OUTPUT  : UPDATED STUDENT RECORD
000008 ENVIRONMENT DIVISION.
000009 INPUT-OUTPUT SECTION.
000010 FILE-CONTROL.
000011     SELECT STUDENT-IDX-FILE
000012         ASSIGN TO "../indexed/STUDENTIDX.DAT"
000013         ORGANIZATION IS INDEXED
000014         ACCESS MODE IS DYNAMIC
000015         RECORD KEY IS STUDENT-ID OF IDX-STUDENT-REC
000016         FILE STATUS IS WS-IDX-STATUS.
000017
000018 DATA DIVISION.
000019 FILE SECTION.
000020
000021 FD STUDENT-IDX-FILE.
000022 01 IDX-STUDENT-REC.
000023 COPY "../copybooks/STUDENT.CPY".
000024
000025 WORKING-STORAGE SECTION.
000026 01 WS-IDX-STATUS      PIC XX VALUE SPACES.
000027 01 WS-INPUT-ID        PIC 9(4).
000028 01 WS-TODAY           PIC 9(8).
000029
000030 01 WS-UPDATE-NAME-FLAG PIC X VALUE SPACE.
000031 01 WS-UPDATE-BDAY-FLAG PIC X VALUE SPACE.
000032 01 WS-UPDATE-CRSE-FLAG PIC X VALUE SPACE.
000033
000034 01 WS-NEW-NAME        PIC X(25).
000035 01 WS-NEW-BDAY-IN     PIC X(8).
000036 01 WS-NEW-COURSE      PIC X(16).
000037
000038 01 WS-DASH-LINE       PIC X(75).
000039
000040 01 WS-HEADER-LINE.
000041    05 FILLER          PIC X(5)  VALUE "ID   ".
000042    05 FILLER          PIC X(26)
000043       VALUE "NAME                      ".
000044    05 FILLER          PIC X(9)  VALUE "BDAY     ".
000045    05 FILLER          PIC X(17)
000046       VALUE "COURSE           ".
000047    05 FILLER          PIC X(9)  VALUE "INS-DATE ".
000048    05 FILLER          PIC X(8)  VALUE "UPD-DATE".
000049
000050 01 WS-REPORT-LINE.
000051    05 RPT-ID          PIC 9(4).
000052    05 FILLER          PIC X(1) VALUE SPACE.
000053    05 RPT-NAME        PIC X(25).
000054    05 FILLER          PIC X(1) VALUE SPACE.
000055    05 RPT-BDAY        PIC 9(8).
000056    05 FILLER          PIC X(1) VALUE SPACE.
000057    05 RPT-COURSE      PIC X(16).
000058    05 FILLER          PIC X(1) VALUE SPACE.
000059    05 RPT-INS-DATE    PIC 9(8).
000060    05 FILLER          PIC X(1) VALUE SPACE.
000061    05 RPT-UPD-DATE    PIC 9(8).
000062
000063 PROCEDURE DIVISION.
000064 MAIN-PARA.
000065     MOVE ALL "-" TO WS-DASH-LINE.
000066
000067     DISPLAY WS-DASH-LINE.
000068     DISPLAY "UPDATE STUDENT".
000069     DISPLAY WS-DASH-LINE.
000070
000071     OPEN I-O STUDENT-IDX-FILE.
000072
000073     IF WS-IDX-STATUS NOT = "00"
000074         DISPLAY "OPEN ERROR STATUS: " WS-IDX-STATUS
000075         STOP RUN
000076     END-IF.
000077
000078     ACCEPT WS-TODAY FROM DATE YYYYMMDD.
000079
000080     DISPLAY "ENTER STUDENT ID TO UPDATE: ".
000081     ACCEPT WS-INPUT-ID.
000082
000083     MOVE WS-INPUT-ID TO STUDENT-ID OF IDX-STUDENT-REC.
000084
000085     READ STUDENT-IDX-FILE
000086         KEY IS STUDENT-ID OF IDX-STUDENT-REC
000087         INVALID KEY
000088             DISPLAY "STUDENT NOT FOUND: " WS-INPUT-ID
000089         NOT INVALID KEY
000090             DISPLAY "CURRENT STUDENT DETAILS"
000091             PERFORM DISPLAY-STUDENT
000092             PERFORM ACCEPT-NEW-VALUES
000093             PERFORM UPDATE-RECORD
000094     END-READ.
000095
000096     CLOSE STUDENT-IDX-FILE.
000097
000098     STOP RUN.
000099
000100 ACCEPT-NEW-VALUES.
000101     MOVE SPACES TO WS-UPDATE-NAME-FLAG.
000102     MOVE SPACES TO WS-UPDATE-BDAY-FLAG.
000103     MOVE SPACES TO WS-UPDATE-CRSE-FLAG.
000104     MOVE SPACES TO WS-NEW-NAME.
000105     MOVE SPACES TO WS-NEW-BDAY-IN.
000106     MOVE SPACES TO WS-NEW-COURSE.
000107
000108     DISPLAY "UPDATE NAME? Y/N: ".
000109     ACCEPT WS-UPDATE-NAME-FLAG.
000110
000111     IF WS-UPDATE-NAME-FLAG = "Y"
000112        OR WS-UPDATE-NAME-FLAG = "y"
000113         DISPLAY "ENTER NEW NAME: "
000114         ACCEPT WS-NEW-NAME
000115         MOVE WS-NEW-NAME
000116             TO STUDENT-NAME OF IDX-STUDENT-REC
000117     END-IF.
000118
000119     DISPLAY "UPDATE BIRTHDAY? Y/N: ".
000120     ACCEPT WS-UPDATE-BDAY-FLAG.
000121
000122     IF WS-UPDATE-BDAY-FLAG = "Y"
000123        OR WS-UPDATE-BDAY-FLAG = "y"
000124         DISPLAY "ENTER NEW BIRTHDAY YYYYMMDD: "
000125         ACCEPT WS-NEW-BDAY-IN
000126         MOVE WS-NEW-BDAY-IN
000127             TO STUDENT-BIRTHDAY OF IDX-STUDENT-REC
000128     END-IF.
000129
000130     DISPLAY "UPDATE COURSE? Y/N: ".
000131     ACCEPT WS-UPDATE-CRSE-FLAG.
000132
000133     IF WS-UPDATE-CRSE-FLAG = "Y"
000134        OR WS-UPDATE-CRSE-FLAG = "y"
000135         DISPLAY "ENTER NEW COURSE: "
000136         ACCEPT WS-NEW-COURSE
000137         MOVE WS-NEW-COURSE
000138             TO STUDENT-COURSE OF IDX-STUDENT-REC
000139     END-IF.
000140
000141     MOVE WS-TODAY
000142         TO STUDENT-UPD-DATE OF IDX-STUDENT-REC.
000143
000144 UPDATE-RECORD.
000145     REWRITE IDX-STUDENT-REC
000146         INVALID KEY
000147             DISPLAY "UPDATE FAILED. STATUS: " WS-IDX-STATUS
000148         NOT INVALID KEY
000149             DISPLAY "STUDENT UPDATED SUCCESSFULLY."
000150             PERFORM DISPLAY-STUDENT
000151     END-REWRITE.
000152
000153 DISPLAY-STUDENT.
000154     DISPLAY WS-DASH-LINE.
000155     DISPLAY WS-HEADER-LINE.
000156     DISPLAY WS-DASH-LINE.
000157     MOVE SPACES TO WS-REPORT-LINE.
000158     MOVE STUDENT-ID OF IDX-STUDENT-REC
000159         TO RPT-ID.
000160     MOVE STUDENT-NAME OF IDX-STUDENT-REC
000161         TO RPT-NAME.
000162     MOVE STUDENT-BIRTHDAY OF IDX-STUDENT-REC
000163         TO RPT-BDAY.
000164     MOVE STUDENT-COURSE OF IDX-STUDENT-REC
000165         TO RPT-COURSE.
000166     MOVE STUDENT-INS-DATE OF IDX-STUDENT-REC
000167         TO RPT-INS-DATE.
000168     MOVE STUDENT-UPD-DATE OF IDX-STUDENT-REC
000169         TO RPT-UPD-DATE.
000170     DISPLAY WS-REPORT-LINE.
000171     DISPLAY WS-DASH-LINE.
000172 END PROGRAM PRGU0003.
