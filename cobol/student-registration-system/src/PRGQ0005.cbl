000001 IDENTIFICATION DIVISION.
000002 PROGRAM-ID. PRGQ0005.
000003 AUTHOR. SRIDHAR.
000004*PROGRAM : PRGQ0005
000005*PURPOSE : QUERY ALL STUDENTS FROM INDEXED FILE
000006*INPUT   : STUDENTIDX.DAT
000007*OUTPUT  : CLASS REPORT DISPLAY
000008 ENVIRONMENT DIVISION.
000009 INPUT-OUTPUT SECTION.
000010 FILE-CONTROL.
000011     SELECT STUDENT-IDX-FILE
000012         ASSIGN TO "../indexed/STUDENTIDX.DAT"
000013         ORGANIZATION IS INDEXED
000014         ACCESS MODE IS SEQUENTIAL
000015         RECORD KEY IS STUDENT-ID OF IDX-STUDENT-REC
000016         FILE STATUS IS WS-IDX-STATUS.
000017
000018 DATA DIVISION.
000019 FILE SECTION.
000020
000021 FD STUDENT-IDX-FILE.
000022 01 IDX-STUDENT-REC.
000023 COPY "../copybooks/STUDENT.CPY".
000024
000025 WORKING-STORAGE SECTION.
000026 01 WS-EOF             PIC X VALUE "N".
000027    88 EOF-REACHED     VALUE "Y".
000028    88 NOT-EOF         VALUE "N".
000029
000030 01 WS-COUNT           PIC 9(4) VALUE 0.
000031 01 WS-IDX-STATUS      PIC XX VALUE SPACES.
000032
000033 01 WS-DASH-LINE       PIC X(80).
000034
000035 01 WS-TITLE-LINE.
000036    05 FILLER          PIC X(30) VALUE SPACES.
000037    05 FILLER          PIC X(20) VALUE "CLASS REPORT".
000038
000039 01 WS-HEADER-LINE.
000040    05 FILLER          PIC X(5)  VALUE "ID".
000041    05 FILLER          PIC X(3)  VALUE " | ".
000042    05 FILLER          PIC X(25) VALUE "STUDENT NAME".
000043    05 FILLER          PIC X(3)  VALUE " | ".
000044    05 FILLER          PIC X(8)  VALUE "BIRTHDAY".
000045    05 FILLER          PIC X(3)  VALUE " | ".
000046    05 FILLER          PIC X(8)  VALUE "COURSE".
000047    05 FILLER          PIC X(06) VALUE SPACES.
000048    05 FILLER          PIC X(3)  VALUE " | ".
000049    05 FILLER          PIC X(11) VALUE "INSERT DATE".
000050    05 FILLER          PIC X(3)  VALUE " | ".
000051    05 FILLER          PIC X(11) VALUE "UPDATE DATE".
000052
000053 01 WS-REPORT-LINE.
000054    05 RPT-ID          PIC 9(4).
000055    05 FILLER          PIC X(3) VALUE " | ".
000056    05 RPT-NAME        PIC X(25).
000057    05 FILLER          PIC X(3) VALUE " | ".
000058    05 RPT-BDAY        PIC 9(8).
000059    05 FILLER          PIC X(3) VALUE " | ".
000060    05 RPT-COURSE      PIC X(16).
000061    05 FILLER          PIC X(3) VALUE " | ".
000062    05 RPT-INS-DATE    PIC 9(8).
000063    05 FILLER          PIC X(3) VALUE " | ".
000064    05 RPT-UPD-DATE    PIC 9(8).
000065
000066 PROCEDURE DIVISION.
000067 MAIN-PARA.
000068     MOVE ALL "-" TO WS-DASH-LINE.
000069
000070     DISPLAY WS-DASH-LINE.
000071     DISPLAY WS-TITLE-LINE.
000072     DISPLAY WS-DASH-LINE.
000073     DISPLAY WS-HEADER-LINE.
000074     DISPLAY WS-DASH-LINE.
000075
000076     OPEN INPUT STUDENT-IDX-FILE.
000077
000078     IF WS-IDX-STATUS NOT = "00"
000079         DISPLAY "OPEN ERROR STATUS: " WS-IDX-STATUS
000080         STOP RUN
000081     END-IF.
000082
000083     PERFORM UNTIL EOF-REACHED
000084         READ STUDENT-IDX-FILE NEXT RECORD
000085             AT END
000086                 SET EOF-REACHED TO TRUE
000087             NOT AT END
000088                 ADD 1 TO WS-COUNT
000089                 PERFORM BUILD-REPORT-LINE
000090                 DISPLAY WS-REPORT-LINE
000091         END-READ
000092     END-PERFORM.
000093
000094     CLOSE STUDENT-IDX-FILE.
000095
000096     DISPLAY WS-DASH-LINE.
000097     DISPLAY "TOTAL STUDENTS: " WS-COUNT.
000098     DISPLAY WS-DASH-LINE.
000099
000100     STOP RUN.
000101
000102 BUILD-REPORT-LINE.
000103     MOVE SPACES TO WS-REPORT-LINE.
000104     MOVE STUDENT-ID OF IDX-STUDENT-REC
000105         TO RPT-ID.
000106     MOVE STUDENT-NAME OF IDX-STUDENT-REC
000107         TO RPT-NAME.
000108     MOVE STUDENT-BIRTHDAY OF IDX-STUDENT-REC
000109         TO RPT-BDAY.
000110     MOVE STUDENT-COURSE OF IDX-STUDENT-REC
000111         TO RPT-COURSE.
000112     MOVE STUDENT-INS-DATE OF IDX-STUDENT-REC
000113         TO RPT-INS-DATE.
000114     MOVE STUDENT-UPD-DATE OF IDX-STUDENT-REC
000115         TO RPT-UPD-DATE.
000116 END PROGRAM PRGQ0005.
