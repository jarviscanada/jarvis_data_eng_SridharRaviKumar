000001 IDENTIFICATION DIVISION.
000002 PROGRAM-ID. PRGR0008.
000003 AUTHOR. SRIDHAR.
000004*GENERATE CLASS REPORT WITH COURSE BREAK
000005 ENVIRONMENT DIVISION.
000006 INPUT-OUTPUT SECTION.
000007 FILE-CONTROL.
000008     SELECT STUDENT-IDX-FILE
000009         ASSIGN TO "../indexed/STUDENTIDX.DAT"
000010         ORGANIZATION IS INDEXED
000011         ACCESS MODE IS SEQUENTIAL
000012         RECORD KEY IS STUDENT-ID OF IDX-STUDENT-REC
000013         FILE STATUS IS WS-IDX-STATUS.
000014
000015     SELECT REPORT-FILE
000016         ASSIGN TO "../data/COURSE_REPORT.DAT"
000017         ORGANIZATION IS LINE SEQUENTIAL
000018         FILE STATUS IS WS-RPT-STATUS.
000019
000020 DATA DIVISION.
000021 FILE SECTION.
000022
000023 FD STUDENT-IDX-FILE.
000024 01 IDX-STUDENT-REC.
000025 COPY "../copybooks/STUDENT.CPY".
000026
000027 FD REPORT-FILE.
000028 01 REPORT-REC         PIC X(100).
000029
000030 WORKING-STORAGE SECTION.
000031 01 WS-EOF             PIC X VALUE "N".
000032    88 EOF-REACHED     VALUE "Y".
000033    88 NOT-EOF         VALUE "N".
000034
000035 01 WS-IDX-STATUS      PIC XX VALUE SPACES.
000036 01 WS-RPT-STATUS      PIC XX VALUE SPACES.
000037
000038 01 WS-COUNT           PIC 9(4) VALUE 0.
000039 01 WS-I               PIC 9(4) VALUE 0.
000040 01 WS-J               PIC 9(4) VALUE 0.
000041 01 WS-J-START         PIC 9(4) VALUE 0.
000042
000043 01 WS-CURRENT-COURSE  PIC X(16) VALUE SPACES.
000044
000045 01 WS-DASH-LINE       PIC X(80).
000046
000047 01 WS-TITLE-LINE.
000048    05 FILLER          PIC X(30) VALUE SPACES.
000049    05 FILLER          PIC X(20) VALUE "CLASS REPORT".
000050
000051 01 WS-COURSE-LINE.
000052    05 FILLER          PIC X(8)  VALUE "COURSE: ".
000053    05 RPT-COURSE-NAME PIC X(16).
000054
000055 01 WS-HEADER-LINE.
000056    05 FILLER          PIC X(5)  VALUE "ID".
000057    05 FILLER          PIC X(3)  VALUE " | ".
000058    05 FILLER          PIC X(25) VALUE "STUDENT NAME".
000059    05 FILLER          PIC X(3)  VALUE " | ".
000060    05 FILLER          PIC X(8)  VALUE "BIRTHDAY".
000061    05 FILLER          PIC X(3)  VALUE " | ".
000062    05 FILLER          PIC X(11) VALUE "INSERT DATE".
000063    05 FILLER          PIC X(3)  VALUE " | ".
000064    05 FILLER          PIC X(11) VALUE "UPDATE DATE".
000065
000066 01 WS-REPORT-LINE.
000067    05 RPT-ID          PIC 9(4).
000068    05 FILLER          PIC X(3) VALUE " | ".
000069    05 RPT-NAME        PIC X(25).
000070    05 FILLER          PIC X(3) VALUE " | ".
000071    05 RPT-BDAY        PIC 9(8).
000072    05 FILLER          PIC X(3) VALUE " | ".
000073    05 RPT-INS-DATE    PIC 9(8).
000074    05 FILLER          PIC X(3) VALUE " | ".
000075    05 RPT-UPD-DATE    PIC 9(8).
000076
000077 01 WS-TOTAL-LINE.
000078    05 FILLER          PIC X(17) VALUE "TOTAL STUDENTS: ".
000079    05 RPT-TOTAL       PIC 9(4).
000080
000081 01 WS-STUDENT-TABLE.
000082    05 WS-STUDENT-ENTRY OCCURS 100 TIMES.
000083       10 TBL-ID        PIC 9(4).
000084       10 TBL-NAME      PIC X(25).
000085       10 TBL-BDAY      PIC 9(8).
000086       10 TBL-COURSE    PIC X(16).
000087       10 TBL-INS-DATE  PIC 9(8).
000088       10 TBL-UPD-DATE  PIC 9(8).
000089
000090 01 WS-TEMP-STUDENT.
000091    05 TMP-ID           PIC 9(4).
000092    05 TMP-NAME         PIC X(25).
000093    05 TMP-BDAY         PIC 9(8).
000094    05 TMP-COURSE       PIC X(16).
000095    05 TMP-INS-DATE     PIC 9(8).
000096    05 TMP-UPD-DATE     PIC 9(8).
000097
000098 PROCEDURE DIVISION.
000099 MAIN-PARA.
000100     MOVE ALL "-" TO WS-DASH-LINE.
000101
000102     DISPLAY WS-DASH-LINE.
000103     DISPLAY "PRGR0008 - COURSE BREAK REPORT".
000104     DISPLAY WS-DASH-LINE.
000105
000106     OPEN INPUT STUDENT-IDX-FILE.
000107
000108     IF WS-IDX-STATUS NOT = "00"
000109         DISPLAY "INPUT OPEN ERROR: " WS-IDX-STATUS
000110         STOP RUN
000111     END-IF.
000112
000113     OPEN OUTPUT REPORT-FILE.
000114
000115     IF WS-RPT-STATUS NOT = "00"
000116         DISPLAY "REPORT OPEN ERROR: " WS-RPT-STATUS
000117         CLOSE STUDENT-IDX-FILE
000118         STOP RUN
000119     END-IF.
000120
000121     PERFORM LOAD-STUDENTS.
000122     PERFORM SORT-STUDENTS-BY-COURSE.
000123     PERFORM WRITE-REPORT.
000124
000125     CLOSE STUDENT-IDX-FILE.
000126     CLOSE REPORT-FILE.
000127
000128     DISPLAY "REPORT CREATED SUCCESSFULLY."
000129     DISPLAY "FILE: ../data/COURSE_REPORT.DAT".
000130     DISPLAY "TOTAL STUDENTS: " WS-COUNT.
000131
000132     STOP RUN.
000133
000134 LOAD-STUDENTS.
000135     PERFORM UNTIL EOF-REACHED
000136         READ STUDENT-IDX-FILE NEXT RECORD
000137             AT END
000138                 SET EOF-REACHED TO TRUE
000139             NOT AT END
000140                 ADD 1 TO WS-COUNT
000141                 MOVE STUDENT-ID OF IDX-STUDENT-REC
000142                     TO TBL-ID(WS-COUNT)
000143                 MOVE STUDENT-NAME OF IDX-STUDENT-REC
000144                     TO TBL-NAME(WS-COUNT)
000145                 MOVE STUDENT-BIRTHDAY OF IDX-STUDENT-REC
000146                     TO TBL-BDAY(WS-COUNT)
000147                 MOVE STUDENT-COURSE OF IDX-STUDENT-REC
000148                     TO TBL-COURSE(WS-COUNT)
000149                 MOVE STUDENT-INS-DATE OF IDX-STUDENT-REC
000150                     TO TBL-INS-DATE(WS-COUNT)
000151                 MOVE STUDENT-UPD-DATE OF IDX-STUDENT-REC
000152                     TO TBL-UPD-DATE(WS-COUNT)
000153         END-READ
000154     END-PERFORM.
000155
000156 SORT-STUDENTS-BY-COURSE.
000157     PERFORM VARYING WS-I FROM 1 BY 1
000158         UNTIL WS-I >= WS-COUNT
000159         COMPUTE WS-J-START = WS-I + 1
000160         PERFORM VARYING WS-J FROM WS-J-START BY 1
000161             UNTIL WS-J > WS-COUNT
000162             IF TBL-COURSE(WS-J) < TBL-COURSE(WS-I)
000163                 PERFORM SWAP-STUDENTS
000164             END-IF
000165         END-PERFORM
000166     END-PERFORM.
000167
000168 SWAP-STUDENTS.
000169     MOVE TBL-ID(WS-I)       TO TMP-ID.
000170     MOVE TBL-NAME(WS-I)     TO TMP-NAME.
000171     MOVE TBL-BDAY(WS-I)     TO TMP-BDAY.
000172     MOVE TBL-COURSE(WS-I)   TO TMP-COURSE.
000173     MOVE TBL-INS-DATE(WS-I) TO TMP-INS-DATE.
000174     MOVE TBL-UPD-DATE(WS-I) TO TMP-UPD-DATE.
000175
000176     MOVE TBL-ID(WS-J)       TO TBL-ID(WS-I).
000177     MOVE TBL-NAME(WS-J)     TO TBL-NAME(WS-I).
000178     MOVE TBL-BDAY(WS-J)     TO TBL-BDAY(WS-I).
000179     MOVE TBL-COURSE(WS-J)   TO TBL-COURSE(WS-I).
000180     MOVE TBL-INS-DATE(WS-J) TO TBL-INS-DATE(WS-I).
000181     MOVE TBL-UPD-DATE(WS-J) TO TBL-UPD-DATE(WS-I).
000182
000183     MOVE TMP-ID             TO TBL-ID(WS-J).
000184     MOVE TMP-NAME           TO TBL-NAME(WS-J).
000185     MOVE TMP-BDAY           TO TBL-BDAY(WS-J).
000186     MOVE TMP-COURSE         TO TBL-COURSE(WS-J).
000187     MOVE TMP-INS-DATE       TO TBL-INS-DATE(WS-J).
000188     MOVE TMP-UPD-DATE       TO TBL-UPD-DATE(WS-J).
000189
000190 WRITE-REPORT.
000191     MOVE WS-DASH-LINE TO REPORT-REC.
000192     WRITE REPORT-REC.
000193     MOVE WS-TITLE-LINE TO REPORT-REC.
000194     WRITE REPORT-REC.
000195     MOVE WS-DASH-LINE TO REPORT-REC.
000196     WRITE REPORT-REC.
000197
000198     MOVE SPACES TO WS-CURRENT-COURSE.
000199
000200     PERFORM VARYING WS-I FROM 1 BY 1
000201         UNTIL WS-I > WS-COUNT
000202         IF TBL-COURSE(WS-I) NOT = WS-CURRENT-COURSE
000203             MOVE TBL-COURSE(WS-I) TO WS-CURRENT-COURSE
000204             MOVE WS-CURRENT-COURSE TO RPT-COURSE-NAME
000205             MOVE SPACES TO REPORT-REC
000206             WRITE REPORT-REC
000207             MOVE WS-COURSE-LINE TO REPORT-REC
000208             WRITE REPORT-REC
000209             MOVE WS-DASH-LINE TO REPORT-REC
000210             WRITE REPORT-REC
000211             MOVE WS-HEADER-LINE TO REPORT-REC
000212             WRITE REPORT-REC
000213             MOVE WS-DASH-LINE TO REPORT-REC
000214             WRITE REPORT-REC
000215         END-IF
000216         PERFORM BUILD-REPORT-LINE
000217         MOVE WS-REPORT-LINE TO REPORT-REC
000218         WRITE REPORT-REC
000219     END-PERFORM.
000220
000221     MOVE WS-DASH-LINE TO REPORT-REC.
000222     WRITE REPORT-REC.
000223     MOVE WS-COUNT TO RPT-TOTAL.
000224     MOVE WS-TOTAL-LINE TO REPORT-REC.
000225     WRITE REPORT-REC.
000226
000227 BUILD-REPORT-LINE.
000228     MOVE SPACES TO WS-REPORT-LINE.
000229     MOVE TBL-ID(WS-I)       TO RPT-ID.
000230     MOVE TBL-NAME(WS-I)     TO RPT-NAME.
000231     MOVE TBL-BDAY(WS-I)     TO RPT-BDAY.
000232     MOVE TBL-INS-DATE(WS-I) TO RPT-INS-DATE.
000233     MOVE TBL-UPD-DATE(WS-I) TO RPT-UPD-DATE.
000234 END PROGRAM PRGR0008.
