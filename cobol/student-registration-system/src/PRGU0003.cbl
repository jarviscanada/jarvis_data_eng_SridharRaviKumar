000001 IDENTIFICATION DIVISION.
000002 PROGRAM-ID. PRGU0003.
000003*Update student information in indexed file.
000004 ENVIRONMENT DIVISION.
000005 INPUT-OUTPUT SECTION.
000006 FILE-CONTROL.
000007     SELECT STUDENT-IDX-FILE
000008         ASSIGN TO "../indexed/STUDENTIDX.DAT"
000009         ORGANIZATION IS INDEXED
000010         ACCESS MODE IS DYNAMIC
000011         RECORD KEY IS STUDENT-ID OF IDX-STUDENT-REC
000012         FILE STATUS IS WS-FILE-STATUS.
000013
000014 DATA DIVISION.
000015 FILE SECTION.
000016 FD STUDENT-IDX-FILE.
000017 01 IDX-STUDENT-REC.
000018 COPY "../copybooks/STUDENT.CPY".
000019
000020 WORKING-STORAGE SECTION.
000021 01 WS-FILE-STATUS        PIC XX.
000022
000023 01 WS-STUDENT-ID-IN      PIC X(4).
000024 01 WS-TODAY              PIC 9(8).
000025 01 WS-CURRENT-YEAR       PIC 9(4).
000026
000027 01 WS-UPDATE-NAME-FLAG   PIC X.
000028 01 WS-UPDATE-BDAY-FLAG   PIC X.
000029 01 WS-UPDATE-CRSE-FLAG   PIC X.
000030
000031 01 WS-NEW-NAME           PIC X(25).
000032 01 WS-NEW-BDAY-IN        PIC X(8).
000033 01 WS-NEW-COURSE         PIC X(16).
000034
000035 01 WS-VALID-FLAG         PIC X VALUE "N".
000036    88 VALID-INPUT        VALUE "Y".
000037    88 INVALID-INPUT      VALUE "N".
000038
000039 01 WS-DATE-VALID-FLAG    PIC X VALUE "N".
000040    88 VALID-DATE         VALUE "Y".
000041    88 INVALID-DATE       VALUE "N".
000042
000043 01 WS-YEAR               PIC 9(4).
000044 01 WS-MONTH              PIC 9(2).
000045 01 WS-DAY                PIC 9(2).
000046 01 WS-MAX-DAY            PIC 9(2).
000047
000048 01 WS-REM-4              PIC 9(4).
000049 01 WS-REM-100            PIC 9(4).
000050 01 WS-REM-400            PIC 9(4).
000051
000052 01 WS-LEAP-FLAG          PIC X VALUE "N".
000053    88 LEAP-YEAR          VALUE "Y".
000054    88 NOT-LEAP-YEAR      VALUE "N".
000055
000056 01 WS-DASH-LINE          PIC X(75)
000057     VALUE ALL "-".
000058
000059 01 WS-HEADER-LINE.
000060    05 FILLER             PIC X(5)  VALUE "ID".
000061    05 FILLER             PIC X(3)  VALUE " | ".
000062    05 FILLER             PIC X(25) VALUE "NAME".
000063    05 FILLER             PIC X(3)  VALUE " | ".
000064    05 FILLER             PIC X(8)  VALUE "BIRTHDAY".
000065    05 FILLER             PIC X(3)  VALUE " | ".
000066    05 FILLER             PIC X(16) VALUE "COURSE".
000067
000068 01 WS-REPORT-LINE.
000069    05 RPT-ID             PIC 9(4).
000070    05 FILLER             PIC X(3)  VALUE " | ".
000071    05 RPT-NAME           PIC X(25).
000072    05 FILLER             PIC X(3)  VALUE " | ".
000073    05 RPT-BDAY           PIC 9(8).
000074    05 FILLER             PIC X(3)  VALUE " | ".
000075    05 RPT-COURSE         PIC X(16).
000076
000077 PROCEDURE DIVISION.
000078 MAIN-PARA.
000079     ACCEPT WS-TODAY FROM DATE YYYYMMDD.
000080     MOVE WS-TODAY(1:4) TO WS-CURRENT-YEAR.
000081
000082     PERFORM ACCEPT-STUDENT-ID.
000083
000084     OPEN I-O STUDENT-IDX-FILE.
000085
000086     IF WS-FILE-STATUS NOT = "00"
000087         DISPLAY "ERROR OPENING STUDENT FILE."
000088         DISPLAY "FILE STATUS: " WS-FILE-STATUS
000089         GOBACK
000090     END-IF.
000091
000092     MOVE WS-STUDENT-ID-IN
000093         TO STUDENT-ID OF IDX-STUDENT-REC.
000094
000095     READ STUDENT-IDX-FILE
000096         INVALID KEY
000097             DISPLAY "STUDENT ID NOT FOUND."
000098             DISPLAY "FILE STATUS: " WS-FILE-STATUS
000099         NOT INVALID KEY
000100             DISPLAY "CURRENT STUDENT RECORD:"
000101             PERFORM DISPLAY-STUDENT
000102             PERFORM ACCEPT-NEW-VALUES
000103             PERFORM UPDATE-RECORD
000104     END-READ.
000105
000106     CLOSE STUDENT-IDX-FILE.
000107
000108     GOBACK.
000109
000110 ACCEPT-STUDENT-ID.
000111     SET INVALID-INPUT TO TRUE.
000112
000113     PERFORM UNTIL VALID-INPUT
000114         DISPLAY "ENTER STUDENT ID TO UPDATE: "
000115         ACCEPT WS-STUDENT-ID-IN
000116
000117         IF WS-STUDENT-ID-IN = SPACES
000118             DISPLAY "STUDENT ID CANNOT BE EMPTY."
000119         ELSE
000120             IF WS-STUDENT-ID-IN IS NUMERIC
000121                 SET VALID-INPUT TO TRUE
000122             ELSE
000123                 DISPLAY "STUDENT ID MUST BE NUMERIC."
000124             END-IF
000125         END-IF
000126     END-PERFORM.
000127
000128 ACCEPT-NEW-VALUES.
000129     MOVE SPACES TO WS-UPDATE-NAME-FLAG.
000130     MOVE SPACES TO WS-UPDATE-BDAY-FLAG.
000131     MOVE SPACES TO WS-UPDATE-CRSE-FLAG.
000132     MOVE SPACES TO WS-NEW-NAME.
000133     MOVE SPACES TO WS-NEW-BDAY-IN.
000134     MOVE SPACES TO WS-NEW-COURSE.
000135
000136     PERFORM ACCEPT-NAME-OPTION.
000137
000138     IF WS-UPDATE-NAME-FLAG = "Y"
000139        OR WS-UPDATE-NAME-FLAG = "y"
000140         PERFORM ACCEPT-NEW-NAME
000141     END-IF.
000142
000143     PERFORM ACCEPT-BDAY-OPTION.
000144
000145     IF WS-UPDATE-BDAY-FLAG = "Y"
000146        OR WS-UPDATE-BDAY-FLAG = "y"
000147         PERFORM ACCEPT-NEW-BDAY
000148     END-IF.
000149
000150     PERFORM ACCEPT-COURSE-OPTION.
000151
000152     IF WS-UPDATE-CRSE-FLAG = "Y"
000153        OR WS-UPDATE-CRSE-FLAG = "y"
000154         PERFORM ACCEPT-NEW-COURSE
000155     END-IF.
000156
000157     MOVE WS-TODAY
000158         TO STUDENT-UPD-DATE OF IDX-STUDENT-REC.
000159
000160 ACCEPT-NAME-OPTION.
000161     SET INVALID-INPUT TO TRUE.
000162
000163     PERFORM UNTIL VALID-INPUT
000164         DISPLAY "UPDATE NAME? Y/N: "
000165         ACCEPT WS-UPDATE-NAME-FLAG
000166
000167         IF WS-UPDATE-NAME-FLAG = "Y"
000168            OR WS-UPDATE-NAME-FLAG = "y"
000169            OR WS-UPDATE-NAME-FLAG = "N"
000170            OR WS-UPDATE-NAME-FLAG = "n"
000171             SET VALID-INPUT TO TRUE
000172         ELSE
000173             DISPLAY "PLEASE ENTER Y OR N."
000174         END-IF
000175     END-PERFORM.
000176
000177 ACCEPT-NEW-NAME.
000178     SET INVALID-INPUT TO TRUE.
000179
000180     PERFORM UNTIL VALID-INPUT
000181         DISPLAY "ENTER NEW NAME: "
000182         ACCEPT WS-NEW-NAME
000183
000184         IF WS-NEW-NAME = SPACES
000185             DISPLAY "NAME CANNOT BE EMPTY."
000186         ELSE
000187             IF WS-NEW-NAME IS ALPHABETIC
000188                 SET VALID-INPUT TO TRUE
000189             ELSE
000190                 DISPLAY "NAME MUST USE LETTERS ONLY."
000191             END-IF
000192         END-IF
000193     END-PERFORM.
000194
000195     MOVE WS-NEW-NAME
000196         TO STUDENT-NAME OF IDX-STUDENT-REC.
000197
000198 ACCEPT-BDAY-OPTION.
000199     SET INVALID-INPUT TO TRUE.
000200
000201     PERFORM UNTIL VALID-INPUT
000202         DISPLAY "UPDATE BIRTHDAY? Y/N: "
000203         ACCEPT WS-UPDATE-BDAY-FLAG
000204
000205         IF WS-UPDATE-BDAY-FLAG = "Y"
000206            OR WS-UPDATE-BDAY-FLAG = "y"
000207            OR WS-UPDATE-BDAY-FLAG = "N"
000208            OR WS-UPDATE-BDAY-FLAG = "n"
000209             SET VALID-INPUT TO TRUE
000210         ELSE
000211             DISPLAY "PLEASE ENTER Y OR N."
000212         END-IF
000213     END-PERFORM.
000214
000215 ACCEPT-NEW-BDAY.
000216     SET INVALID-INPUT TO TRUE.
000217
000218     PERFORM UNTIL VALID-INPUT
000219         DISPLAY "ENTER NEW BIRTHDAY YYYYMMDD: "
000220         ACCEPT WS-NEW-BDAY-IN
000221
000222         PERFORM VALIDATE-BIRTHDAY
000223
000224         IF VALID-DATE
000225             SET VALID-INPUT TO TRUE
000226         END-IF
000227     END-PERFORM.
000228
000229     MOVE WS-NEW-BDAY-IN
000230         TO STUDENT-BIRTHDAY OF IDX-STUDENT-REC.
000231
000232 ACCEPT-COURSE-OPTION.
000233     SET INVALID-INPUT TO TRUE.
000234
000235     PERFORM UNTIL VALID-INPUT
000236         DISPLAY "UPDATE COURSE? Y/N: "
000237         ACCEPT WS-UPDATE-CRSE-FLAG
000238
000239         IF WS-UPDATE-CRSE-FLAG = "Y"
000240            OR WS-UPDATE-CRSE-FLAG = "y"
000241            OR WS-UPDATE-CRSE-FLAG = "N"
000242            OR WS-UPDATE-CRSE-FLAG = "n"
000243             SET VALID-INPUT TO TRUE
000244         ELSE
000245             DISPLAY "PLEASE ENTER Y OR N."
000246         END-IF
000247     END-PERFORM.
000248
000249 ACCEPT-NEW-COURSE.
000250     SET INVALID-INPUT TO TRUE.
000251
000252     PERFORM UNTIL VALID-INPUT
000253         DISPLAY "ENTER NEW COURSE: "
000254         ACCEPT WS-NEW-COURSE
000255
000256         IF WS-NEW-COURSE = SPACES
000257             DISPLAY "COURSE CANNOT BE EMPTY."
000258         ELSE
000259             SET VALID-INPUT TO TRUE
000260         END-IF
000261     END-PERFORM.
000262
000263     MOVE WS-NEW-COURSE
000264         TO STUDENT-COURSE OF IDX-STUDENT-REC.
000265
000266 VALIDATE-BIRTHDAY.
000267     SET INVALID-DATE TO TRUE.
000268     MOVE ZERO TO WS-YEAR.
000269     MOVE ZERO TO WS-MONTH.
000270     MOVE ZERO TO WS-DAY.
000271     MOVE ZERO TO WS-MAX-DAY.
000272
000273     IF WS-NEW-BDAY-IN = SPACES
000274         DISPLAY "BIRTHDAY CANNOT BE EMPTY."
000275         EXIT PARAGRAPH
000276     END-IF.
000277
000278     IF WS-NEW-BDAY-IN NOT NUMERIC
000279         DISPLAY "BIRTHDAY MUST BE NUMERIC YYYYMMDD."
000280         EXIT PARAGRAPH
000281     END-IF.
000282
000283     MOVE WS-NEW-BDAY-IN(1:4) TO WS-YEAR.
000284     MOVE WS-NEW-BDAY-IN(5:2) TO WS-MONTH.
000285     MOVE WS-NEW-BDAY-IN(7:2) TO WS-DAY.
000286
000287     IF WS-YEAR < 1900
000288         DISPLAY "YEAR MUST BE 1900 OR LATER."
000289         EXIT PARAGRAPH
000290     END-IF.
000291
000292     IF WS-YEAR > WS-CURRENT-YEAR
000293         DISPLAY "BIRTHDAY CANNOT BE IN FUTURE YEAR."
000294         EXIT PARAGRAPH
000295     END-IF.
000296
000297     IF WS-MONTH < 1 OR WS-MONTH > 12
000298         DISPLAY "MONTH MUST BE BETWEEN 01 AND 12."
000299         EXIT PARAGRAPH
000300     END-IF.
000301
000302     IF WS-MONTH = 1
000303        OR WS-MONTH = 3
000304        OR WS-MONTH = 5
000305        OR WS-MONTH = 7
000306        OR WS-MONTH = 8
000307        OR WS-MONTH = 10
000308        OR WS-MONTH = 12
000309         MOVE 31 TO WS-MAX-DAY
000310     ELSE
000311         IF WS-MONTH = 4
000312            OR WS-MONTH = 6
000313            OR WS-MONTH = 9
000314            OR WS-MONTH = 11
000315             MOVE 30 TO WS-MAX-DAY
000316         ELSE
000317             PERFORM CHECK-LEAP-YEAR
000318
000319             IF LEAP-YEAR
000320                 MOVE 29 TO WS-MAX-DAY
000321             ELSE
000322                 MOVE 28 TO WS-MAX-DAY
000323             END-IF
000324         END-IF
000325     END-IF.
000326
000327     IF WS-DAY < 1 OR WS-DAY > WS-MAX-DAY
000328         DISPLAY "DAY IS NOT VALID FOR THIS MONTH."
000329         EXIT PARAGRAPH
000330     END-IF.
000331
000332     SET VALID-DATE TO TRUE.
000333
000334 CHECK-LEAP-YEAR.
000335     SET NOT-LEAP-YEAR TO TRUE.
000336
000337     COMPUTE WS-REM-4 = FUNCTION MOD(WS-YEAR 4).
000338     COMPUTE WS-REM-100 = FUNCTION MOD(WS-YEAR 100).
000339     COMPUTE WS-REM-400 = FUNCTION MOD(WS-YEAR 400).
000340
000341     IF WS-REM-400 = 0
000342         SET LEAP-YEAR TO TRUE
000343     ELSE
000344         IF WS-REM-4 = 0 AND WS-REM-100 NOT = 0
000345             SET LEAP-YEAR TO TRUE
000346         END-IF
000347     END-IF.
000348
000349 UPDATE-RECORD.
000350     REWRITE IDX-STUDENT-REC
000351         INVALID KEY
000352             DISPLAY "ERROR UPDATING STUDENT RECORD."
000353             DISPLAY "FILE STATUS: " WS-FILE-STATUS
000354         NOT INVALID KEY
000355             DISPLAY "STUDENT RECORD UPDATED SUCCESSFULLY."
000356             DISPLAY "UPDATED STUDENT RECORD:"
000357             PERFORM DISPLAY-STUDENT
000358     END-REWRITE.
000359
000360 DISPLAY-STUDENT.
000361     DISPLAY WS-DASH-LINE.
000362     DISPLAY WS-HEADER-LINE.
000363     DISPLAY WS-DASH-LINE.
000364
000365     MOVE SPACES TO WS-REPORT-LINE.
000366
000367     MOVE STUDENT-ID OF IDX-STUDENT-REC
000368         TO RPT-ID.
000369
000370     MOVE STUDENT-NAME OF IDX-STUDENT-REC
000371         TO RPT-NAME.
000372
000373     MOVE STUDENT-BIRTHDAY OF IDX-STUDENT-REC
000374         TO RPT-BDAY.
000375
000376     MOVE STUDENT-COURSE OF IDX-STUDENT-REC
000377         TO RPT-COURSE.
000378
000379     DISPLAY WS-REPORT-LINE.
000380     DISPLAY WS-DASH-LINE.
000381
000382 END PROGRAM PRGU0003.
