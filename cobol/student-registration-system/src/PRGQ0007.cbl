000001 IDENTIFICATION DIVISION.
000002 PROGRAM-ID. PRGQ0007.
000003 AUTHOR. SRIDHAR.
000004*QUERY STUDENTS BY DATE OF INCLUSION
000005 ENVIRONMENT DIVISION.
000006 INPUT-OUTPUT SECTION.
000007 FILE-CONTROL.
000008     SELECT STUDENT-IDX-FILE
000009         ASSIGN TO "../indexed/STUDENTIDX.DAT"
000010         ORGANIZATION IS INDEXED
000011         ACCESS MODE IS SEQUENTIAL
000012         RECORD KEY IS STUDENT-ID OF IDX-STUDENT-REC
000013         FILE STATUS IS WS-IDX-STATUS.
000014
000015 DATA DIVISION.
000016 FILE SECTION.
000017
000018 FD STUDENT-IDX-FILE.
000019 01 IDX-STUDENT-REC.
000020 COPY "../copybooks/STUDENT.CPY".
000021
000022 WORKING-STORAGE SECTION.
000023 01 WS-EOF             PIC X VALUE "N".
000024    88 EOF-REACHED     VALUE "Y".
000025    88 NOT-EOF         VALUE "N".
000026
000027 01 WS-IDX-STATUS      PIC XX VALUE SPACES.
000028 01 WS-INPUT-DATE      PIC 9(8).
000029 01 WS-MATCH-COUNT     PIC 9(4) VALUE 0.
000030
000031 01 WS-DASH-LINE       PIC X(75).
000032
000033 01 WS-HEADER-LINE.
000034    05 FILLER          PIC X(5)  VALUE "ID   ".
000035    05 FILLER          PIC X(26)
000036       VALUE "NAME                      ".
000037    05 FILLER          PIC X(9)  VALUE "BDAY     ".
000038    05 FILLER          PIC X(17)
000039       VALUE "COURSE           ".
000040    05 FILLER          PIC X(8)  VALUE "UPD-DATE".
000041
000042 01 WS-REPORT-LINE.
000043    05 RPT-ID          PIC 9(4).
000044    05 FILLER          PIC X(1) VALUE SPACE.
000045    05 RPT-NAME        PIC X(25).
000046    05 FILLER          PIC X(1) VALUE SPACE.
000047    05 RPT-BDAY        PIC 9(8).
000048    05 FILLER          PIC X(1) VALUE SPACE.
000049    05 RPT-COURSE      PIC X(16).
000050    05 FILLER          PIC X(1) VALUE SPACE.
000051    05 RPT-UPD-DATE    PIC 9(8).
000052
000053 PROCEDURE DIVISION.
000054 MAIN-PARA.
000055     MOVE ALL "-" TO WS-DASH-LINE.
000056
000057     DISPLAY WS-DASH-LINE.
000058     DISPLAY "QUERY STUDENT BY DATE OF INCLUSION".
000059     DISPLAY WS-DASH-LINE.
000060
000061     OPEN INPUT STUDENT-IDX-FILE.
000062
000063     IF WS-IDX-STATUS NOT = "00"
000064         DISPLAY "OPEN ERROR STATUS: " WS-IDX-STATUS
000065         STOP RUN
000066     END-IF.
000067
000068     DISPLAY "ENTER DATE OF INCLUSION YYYYMMDD: ".
000069     ACCEPT WS-INPUT-DATE.
000070
000071     DISPLAY WS-DASH-LINE.
000072     DISPLAY "LIST OF STUDENTS INCLUDED ON: "
000073             WS-INPUT-DATE.
000074     DISPLAY WS-DASH-LINE.
000075     DISPLAY WS-HEADER-LINE.
000076     DISPLAY WS-DASH-LINE.
000077
000078     PERFORM UNTIL EOF-REACHED
000079         READ STUDENT-IDX-FILE NEXT RECORD
000080             AT END
000081                 SET EOF-REACHED TO TRUE
000082             NOT AT END
000083                 IF STUDENT-INS-DATE OF IDX-STUDENT-REC
000084                    = WS-INPUT-DATE
000085                     ADD 1 TO WS-MATCH-COUNT
000086                     PERFORM DISPLAY-STUDENT
000087                 END-IF
000088         END-READ
000089     END-PERFORM.
000090
000091     DISPLAY WS-DASH-LINE.
000092
000093     IF WS-MATCH-COUNT = 0
000094         DISPLAY "NO STUDENTS FOUND FOR DATE: "
000095                 WS-INPUT-DATE
000096     ELSE
000097         DISPLAY "TOTAL RECORDS: " WS-MATCH-COUNT
000098     END-IF.
000099
000100     DISPLAY WS-DASH-LINE.
000101
000102     CLOSE STUDENT-IDX-FILE.
000103
000104     GOBACK.
000105
000106 DISPLAY-STUDENT.
000107     MOVE SPACES TO WS-REPORT-LINE.
000108     MOVE STUDENT-ID OF IDX-STUDENT-REC
000109         TO RPT-ID.
000110     MOVE STUDENT-NAME OF IDX-STUDENT-REC
000111         TO RPT-NAME.
000112     MOVE STUDENT-BIRTHDAY OF IDX-STUDENT-REC
000113         TO RPT-BDAY.
000114     MOVE STUDENT-COURSE OF IDX-STUDENT-REC
000115         TO RPT-COURSE.
000116     MOVE STUDENT-UPD-DATE OF IDX-STUDENT-REC
000117         TO RPT-UPD-DATE.
000118     DISPLAY WS-REPORT-LINE.
000119 END PROGRAM PRGQ0007.
