000001 IDENTIFICATION DIVISION.
000002 PROGRAM-ID. PRGI0002.
000003 AUTHOR. SRIDHAR.
000004*INSERT STUDENT INTO INDEXED FILE
000005 ENVIRONMENT DIVISION.
000006 INPUT-OUTPUT SECTION.
000007 FILE-CONTROL.
000008     SELECT STUDENT-IDX-FILE
000009         ASSIGN TO "../indexed/STUDENTIDX.DAT"
000010         ORGANIZATION IS INDEXED
000011         ACCESS MODE IS DYNAMIC
000012         RECORD KEY IS STUDENT-ID OF IDX-STUDENT-REC
000013         FILE STATUS IS WS-IDX-STATUS.
000014
000015 DATA DIVISION.
000016 FILE SECTION.
000017
000018 FD STUDENT-IDX-FILE.
000019 01 IDX-STUDENT-REC.
000020 COPY "../copybooks/STUDENT.CPY".
000021
000022 WORKING-STORAGE SECTION.
000023 01 WS-IDX-STATUS      PIC XX VALUE SPACES.
000024 01 WS-TODAY           PIC 9(8).
000025
000026 01 WS-DASH-LINE       PIC X(55).
000027
000028 01 WS-HEADER-LINE.
000029    05 FILLER          PIC X(5)  VALUE "ID   ".
000030    05 FILLER          PIC X(26)
000031       VALUE "NAME                      ".
000032    05 FILLER          PIC X(9)  VALUE "BDAY     ".
000033    05 FILLER          PIC X(15) VALUE "COURSE".
000034
000035 01 WS-REPORT-LINE.
000036    05 RPT-ID          PIC 9(4).
000037    05 FILLER          PIC X(1) VALUE SPACE.
000038    05 RPT-NAME        PIC X(25).
000039    05 FILLER          PIC X(1) VALUE SPACE.
000040    05 RPT-BDAY        PIC 9(8).
000041    05 FILLER          PIC X(1) VALUE SPACE.
000042    05 RPT-COURSE      PIC X(16).
000043
000044 PROCEDURE DIVISION.
000045 MAIN-PARA.
000046     MOVE ALL "-" TO WS-DASH-LINE.
000047
000048     DISPLAY WS-DASH-LINE.
000049     DISPLAY "INSERT STUDENT".
000050     DISPLAY WS-DASH-LINE.
000051
000052     OPEN I-O STUDENT-IDX-FILE.
000053
000054     IF WS-IDX-STATUS NOT = "00"
000055         DISPLAY "OPEN ERROR STATUS: " WS-IDX-STATUS
000056         STOP RUN
000057     END-IF.
000058
000059     ACCEPT WS-TODAY FROM DATE YYYYMMDD.
000060
000061     DISPLAY "ENTER STUDENT ID: ".
000062     ACCEPT STUDENT-ID OF IDX-STUDENT-REC.
000063
000064     DISPLAY "ENTER STUDENT NAME: ".
000065     ACCEPT STUDENT-NAME OF IDX-STUDENT-REC.
000066
000067     DISPLAY "ENTER BIRTHDAY YYYYMMDD: ".
000068     ACCEPT STUDENT-BIRTHDAY OF IDX-STUDENT-REC.
000069
000070     DISPLAY "ENTER COURSE: ".
000071     ACCEPT STUDENT-COURSE OF IDX-STUDENT-REC.
000072
000073     MOVE WS-TODAY TO STUDENT-INS-DATE OF IDX-STUDENT-REC.
000074     MOVE ZEROES   TO STUDENT-UPD-DATE OF IDX-STUDENT-REC.
000075
000076     WRITE IDX-STUDENT-REC
000077         INVALID KEY
000078             DISPLAY "INSERT FAILED. DUPLICATE ID."
000079             DISPLAY "STATUS: " WS-IDX-STATUS
000080         NOT INVALID KEY
000081             DISPLAY "STUDENT INSERTED SUCCESSFULLY."
000082             PERFORM DISPLAY-STUDENT
000083     END-WRITE.
000084
000085     CLOSE STUDENT-IDX-FILE.
000086
000087     GOBACK.
000088
000089 DISPLAY-STUDENT.
000090     DISPLAY WS-DASH-LINE.
000091     DISPLAY WS-HEADER-LINE.
000092     DISPLAY WS-DASH-LINE.
000093     MOVE SPACES TO WS-REPORT-LINE.
000094     MOVE STUDENT-ID OF IDX-STUDENT-REC
000095         TO RPT-ID.
000096     MOVE STUDENT-NAME OF IDX-STUDENT-REC
000097         TO RPT-NAME.
000098     MOVE STUDENT-BIRTHDAY OF IDX-STUDENT-REC
000099         TO RPT-BDAY.
000100     MOVE STUDENT-COURSE OF IDX-STUDENT-REC
000101         TO RPT-COURSE.
000102     DISPLAY WS-REPORT-LINE.
000103     DISPLAY WS-DASH-LINE.
000104 END PROGRAM PRGI0002.
